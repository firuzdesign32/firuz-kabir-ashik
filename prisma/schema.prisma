generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  EDITOR
}

enum Status {
  PUBLISHED
  DRAFT
}

enum ProductType {
  PDF
  TEMPLATE
  LUT
  PRESET
  COURSE_RESOURCE
  ASSET_PACK
  ZIP
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

model User {
  id             String   @id @default(cuid())
  name           String?
  email          String   @unique
  hashedPassword String
  role           Role     @default(EDITOR)
  createdAt      DateTime @default(now())
}

model Portfolio {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  category      String
  thumbnail     String
  coverImage    String
  galleryImages String[]
  videos        String[]
  gifs          String[]
  description   String   @db.Text
  clientName    String?
  projectDate   DateTime?
  tags          String[]
  featured      Boolean  @default(false)
  status        Status   @default(DRAFT)
  displayOrder  Int      @default(0)
  createdAt     DateTime @default(now())
}

model CaseStudy {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique
  category        String
  clientName      String?
  industry        String?
  challenge       String   @db.Text
  solution        String   @db.Text
  process         String   @db.Text
  results         String   @db.Text
  media           String[]
  metaTitle       String?
  metaDescription String?  @db.Text
  ogImage         String?
  createdAt       DateTime @default(now())
}

model Product {
  id              String      @id @default(cuid())
  name            String
  slug            String      @unique
  thumbnail       String
  gallery         String[]
  price           Float
  discountPrice   Float?
  description     String      @db.Text
  category        String
  productFileUrl  String
  previewFileUrl  String?
  type            ProductType
  status          Status      @default(DRAFT)
  createdAt       DateTime    @default(now())
}

model Order {
  id                String    @id @default(cuid())
  customerName      String
  customerEmail     String
  items             Json
  totalAmount       Float
  couponCode        String?
  discountAmount    Float?
  paymentMethod     String
  paymentStatus     String
  paymentId         String?
  downloadToken     String?   @unique @default(uuid())
  downloadExpiresAt DateTime?
  createdAt         DateTime  @default(now())
}

model Coupon {
  id            String       @id @default(cuid())
  code          String       @unique
  discountType  DiscountType
  discountValue Float
  usageLimit    Int?
  usedCount     Int          @default(0)
  expiresAt     DateTime?
  active        Boolean      @default(true)
}

model SiteSettings {
  id    String @id @default(cuid())
  key   String @unique
  value String @db.Text
}

model MediaLibrary {
  id        String   @id @default(cuid())
  url       String
  type      String
  size      Int
  filename  String
  folder    String?
  createdAt DateTime @default(now())
}
